{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mizcausevic-dev/ai-incident-card-spec/blob/main/incident-card.schema.json",
  "title": "AI Incident Card",
  "description": "Schema for an AI Incident Card v0.1 document — vendor-published machine-readable post-incident disclosure for AI agents, tutors, tools, and models. The CVE-equivalent for AI failures.",
  "type": "object",
  "required": [
    "incident_card_version",
    "incident",
    "affected",
    "summary",
    "root_cause",
    "harm",
    "mitigation",
    "published_by",
    "published_at",
    "last_updated_at"
  ],
  "additionalProperties": false,

  "properties": {
    "incident_card_version": { "type": "string", "const": "0.1" },
    "incident": { "$ref": "#/$defs/Incident" },
    "categories_other_text": { "type": "string", "minLength": 1 },
    "affected": { "$ref": "#/$defs/Affected" },
    "summary": { "type": "string", "minLength": 1 },
    "root_cause": { "$ref": "#/$defs/RootCause" },
    "harm": { "$ref": "#/$defs/Harm" },
    "mitigation": { "$ref": "#/$defs/Mitigation" },
    "evidence": { "$ref": "#/$defs/Evidence" },
    "references": {
      "type": "array",
      "items": { "$ref": "#/$defs/Reference" }
    },
    "regulatory": { "$ref": "#/$defs/Regulatory" },
    "withdrawal": { "$ref": "#/$defs/Withdrawal" },
    "published_by": { "$ref": "#/$defs/PublishedBy" },
    "published_at": { "type": "string", "format": "date-time" },
    "last_updated_at": { "type": "string", "format": "date-time" },
    "revision": { "$ref": "#/$defs/Revision" }
  },

  "allOf": [
    {
      "description": "Resolved status requires resolved_at",
      "if": {
        "properties": { "incident": { "properties": { "status": { "const": "resolved" } } } },
        "required": ["incident"]
      },
      "then": {
        "properties": { "incident": { "required": ["resolved_at"] } }
      }
    },
    {
      "description": "Withdrawn status requires withdrawal block",
      "if": {
        "properties": { "incident": { "properties": { "status": { "const": "withdrawn" } } } },
        "required": ["incident"]
      },
      "then": {
        "required": ["withdrawal"]
      }
    },
    {
      "description": "Regulatory filings require URIs",
      "if": {
        "properties": {
          "regulatory": {
            "type": "object",
            "properties": { "reported_to": { "type": "array", "minItems": 1 } },
            "required": ["reported_to"]
          }
        },
        "required": ["regulatory"]
      },
      "then": {
        "properties": {
          "regulatory": {
            "required": ["regulatory_filing_uris"],
            "properties": { "regulatory_filing_uris": { "minItems": 1 } }
          }
        }
      }
    },
    {
      "description": "root_cause.category=other requires category_other_text",
      "if": {
        "properties": {
          "root_cause": { "properties": { "category": { "const": "other" } } }
        },
        "required": ["root_cause"]
      },
      "then": {
        "properties": {
          "root_cause": { "required": ["category_other_text"] }
        }
      }
    },
    {
      "description": "incident.categories containing 'other' requires top-level categories_other_text",
      "if": {
        "properties": {
          "incident": {
            "properties": {
              "categories": { "type": "array", "contains": { "const": "other" } }
            }
          }
        },
        "required": ["incident"]
      },
      "then": {
        "required": ["categories_other_text"]
      }
    }
  ],

  "$defs": {
    "Severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },

    "Status": {
      "type": "string",
      "enum": ["active", "mitigated", "resolved", "withdrawn"]
    },

    "HarmCategory": {
      "type": "string",
      "enum": [
        "misinformation",
        "pii_leak",
        "bias",
        "copyright_violation",
        "mandated_reporter_failure",
        "prompt_injection_success",
        "tool_abuse",
        "jailbreak_success",
        "hallucination_with_consequences",
        "refusal_taxonomy_violation",
        "content_filter_failure",
        "availability_outage",
        "tampering",
        "other"
      ]
    },

    "Incident": {
      "type": "object",
      "required": ["id", "title", "severity", "categories", "discovered_at", "disclosed_at", "status"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9-]*[A-Za-z0-9]$" },
        "title": { "type": "string", "minLength": 1 },
        "severity": { "$ref": "#/$defs/Severity" },
        "categories": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/HarmCategory" },
          "uniqueItems": true
        },
        "discovered_at": { "type": "string", "format": "date-time" },
        "occurred_at": { "type": "string", "format": "date-time" },
        "disclosed_at": { "type": "string", "format": "date-time" },
        "resolved_at": { "type": "string", "format": "date-time" },
        "status": { "$ref": "#/$defs/Status" }
      }
    },

    "Affected": {
      "type": "object",
      "required": ["vendor", "products"],
      "additionalProperties": false,
      "properties": {
        "vendor": { "type": "string", "minLength": 1 },
        "products": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "versions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "agent_card_uris": {
          "type": "array",
          "items": { "type": "string", "format": "uri" },
          "uniqueItems": true
        },
        "tutor_card_uris": {
          "type": "array",
          "items": { "type": "string", "format": "uri" },
          "uniqueItems": true
        },
        "tool_card_uris": {
          "type": "array",
          "items": { "type": "string", "format": "uri" },
          "uniqueItems": true
        },
        "affected_user_count": {
          "type": "object",
          "required": ["kind"],
          "additionalProperties": false,
          "properties": {
            "kind": { "type": "string", "enum": ["exact", "approximate", "unknown"] },
            "count": { "type": "integer", "minimum": 0 }
          }
        },
        "affected_populations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },

    "RootCause": {
      "type": "object",
      "required": ["category", "description"],
      "additionalProperties": false,
      "properties": {
        "category": {
          "type": "string",
          "enum": [
            "training_data",
            "prompt_injection",
            "tool_abuse",
            "refusal_taxonomy_gap",
            "content_filter_gap",
            "retrieval_failure",
            "evaluation_gap",
            "deployment_misconfiguration",
            "supply_chain",
            "other"
          ]
        },
        "description": { "type": "string", "minLength": 1 },
        "category_other_text": { "type": "string", "minLength": 1 }
      }
    },

    "Harm": {
      "type": "object",
      "required": ["severity_justification", "manifested"],
      "additionalProperties": false,
      "properties": {
        "severity_justification": { "type": "string", "minLength": 1 },
        "manifested": { "type": "boolean" },
        "narrative": { "type": "string", "minLength": 1 }
      }
    },

    "Mitigation": {
      "type": "object",
      "required": ["actions_taken", "permanent_fix", "rollout_status"],
      "additionalProperties": false,
      "properties": {
        "actions_taken": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "permanent_fix": { "type": "boolean" },
        "rollout_status": { "type": "string", "enum": ["planned", "in_progress", "deployed"] },
        "workaround_for_users": { "type": "string", "minLength": 1 }
      }
    },

    "Evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "evidence_uris": {
          "type": "array",
          "items": { "type": "string", "format": "uri" }
        },
        "prompt_provenance_uri": { "type": "string", "format": "uri" },
        "reproduction_uri": { "type": "string", "format": "uri" },
        "internal_postmortem_uri": { "type": "string", "format": "uri" }
      }
    },

    "Reference": {
      "type": "object",
      "required": ["type", "title", "uri"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["blog_post", "regulatory_filing", "academic_paper", "press_release", "customer_notice", "other"]
        },
        "title": { "type": "string", "minLength": 1 },
        "uri": { "type": "string", "format": "uri" },
        "published_at": { "type": "string", "format": "date-time" }
      }
    },

    "Regulatory": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reported_to": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "eu-ai-act-art-73",
              "us-omb-m-24-10",
              "ferpa",
              "coppa",
              "hipaa",
              "gdpr",
              "state-attorney-general",
              "fda-21-cfr-11",
              "other"
            ]
          },
          "uniqueItems": true
        },
        "reporting_deadline_met": { "type": "boolean" },
        "regulatory_filing_uris": {
          "type": "array",
          "items": { "type": "string", "format": "uri" },
          "uniqueItems": true
        },
        "not_reportable_justification": { "type": "string", "minLength": 1 }
      }
    },

    "Withdrawal": {
      "type": "object",
      "required": ["withdrawn_at", "reason"],
      "additionalProperties": false,
      "properties": {
        "withdrawn_at": { "type": "string", "format": "date-time" },
        "reason": { "type": "string", "minLength": 1 },
        "replacement_incident_uri": { "type": "string", "format": "uri" }
      }
    },

    "PublishedBy": {
      "type": "object",
      "required": ["name", "role"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "role": {
          "type": "string",
          "enum": ["vendor", "third-party-researcher", "user", "regulator", "auditor"]
        },
        "contact_uri": { "type": "string", "format": "uri" },
        "pgp_fingerprint": { "type": "string", "minLength": 1 }
      }
    },

    "Revision": {
      "type": "object",
      "required": ["number", "change_summary"],
      "additionalProperties": false,
      "properties": {
        "number": { "type": "integer", "minimum": 1 },
        "change_summary": { "type": "string", "minLength": 1 }
      }
    }
  }
}
