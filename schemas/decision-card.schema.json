{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mizcausevic-dev/ai-procurement-decision-spec/blob/main/decision-card.schema.json",
  "title": "AI Procurement Decision Card",
  "description": "A buyer-side artifact recording the outcome of a procurement review of one or more AI vendor declaration documents. Served at /.well-known/decisions/{decision_id}.json (per-decision) or referenced in /.well-known/decisions/index.json. v0.1 draft.",
  "type": "object",
  "required": [
    "decision_card_version",
    "decision_id",
    "issued_at",
    "buyer",
    "decision",
    "subject",
    "rationale"
  ],
  "additionalProperties": false,
  "properties": {
    "decision_card_version": {
      "description": "Spec version. MUST be '0.1' for documents conforming to this draft.",
      "type": "string",
      "const": "0.1"
    },
    "decision_id": {
      "description": "Stable, buyer-issued identifier. Conventionally DEC-<year>-<seq> but any string unique to the buyer is valid.",
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "issued_at": {
      "description": "RFC 3339 timestamp the decision was published.",
      "type": "string",
      "format": "date-time"
    },
    "buyer": { "$ref": "#/$defs/Buyer" },
    "decision_maker": { "$ref": "#/$defs/DecisionMaker" },
    "decision": { "$ref": "#/$defs/Decision" },
    "subject": { "$ref": "#/$defs/Subject" },
    "criteria": { "$ref": "#/$defs/Criteria" },
    "conditions": {
      "type": "array",
      "items": { "$ref": "#/$defs/Condition" },
      "description": "Conditions attached to an approval, or remediation requirements for a rejection. Required when decision.status is 'approved-with-conditions' or 'rejected-with-remediation'."
    },
    "rationale": {
      "description": "Narrative explanation of the decision in human-readable prose.",
      "type": "string",
      "minLength": 1
    },
    "history": {
      "type": "array",
      "items": { "$ref": "#/$defs/HistoryEvent" },
      "description": "Audit trail of state transitions during the review."
    },
    "appeals": { "$ref": "#/$defs/Appeals" },
    "publication": { "$ref": "#/$defs/Publication" },
    "signatures": {
      "type": "array",
      "items": { "$ref": "#/$defs/Signature" }
    },
    "withdrawal": { "$ref": "#/$defs/Withdrawal" }
  },
  "$defs": {
    "Buyer": {
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": ["organization", "agency", "school-district", "school", "hospital", "health-system", "research-institution", "auditor", "individual"]
        },
        "category": {
          "description": "Free-form sub-classification — e.g. 'edtech-district', 'federal-civilian', 'academic-medical-center'.",
          "type": "string"
        },
        "jurisdiction": {
          "description": "ISO 3166-1 alpha-2 country code, optionally with a region (e.g. 'US-CA', 'GB', 'EU').",
          "type": "string",
          "pattern": "^[A-Z]{2}(-[A-Z0-9]{1,3})?$|^EU$"
        },
        "url": { "type": "string", "format": "uri" },
        "contact": { "type": "string", "format": "email" },
        "id": {
          "description": "Stable canonical identifier for the buyer (typically a URI).",
          "type": "string",
          "format": "uri"
        }
      }
    },
    "DecisionMaker": {
      "type": "object",
      "required": ["role"],
      "additionalProperties": false,
      "properties": {
        "role": {
          "description": "Title or role of the individual or committee that made the decision.",
          "type": "string",
          "minLength": 1
        },
        "name": { "type": "string" },
        "department": { "type": "string" },
        "authority": {
          "description": "The formal authority under which the decision was made — e.g. 'Board Resolution 2026-04', 'CMO delegation'.",
          "type": "string"
        }
      }
    },
    "Decision": {
      "type": "object",
      "required": ["status"],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "approved",
            "approved-with-conditions",
            "rejected",
            "rejected-with-remediation",
            "pending",
            "withdrawn",
            "expired"
          ]
        },
        "effective_from": {
          "description": "Date from which the decision takes effect (ISO 8601 date or date-time).",
          "type": "string"
        },
        "effective_until": {
          "description": "Date the decision expires. Decisions with this field set transition to status 'expired' automatically after this date.",
          "type": "string"
        },
        "scope": {
          "description": "Free-form description of where/how the approval applies — e.g. 'K-12 classroom use during regular school hours', 'cardiology imaging only'.",
          "type": "string"
        }
      }
    },
    "Subject": {
      "type": "object",
      "required": ["vendor_name"],
      "additionalProperties": false,
      "properties": {
        "vendor_name": { "type": "string", "minLength": 1 },
        "product_name": { "type": "string" },
        "vendor_id": {
          "description": "Stable canonical identifier for the vendor (typically their AI Entity Card URL).",
          "type": "string",
          "format": "uri"
        },
        "documents_reviewed": {
          "type": "array",
          "items": { "$ref": "#/$defs/DocumentReference" },
          "description": "Vendor declaration documents (AEO entity card, Tool Disclosure, Clinical AI Card, etc.) considered during the review."
        }
      }
    },
    "DocumentReference": {
      "type": "object",
      "required": ["type", "url"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "aeo",
            "prompt-provenance",
            "agent-card",
            "ai-evidence",
            "tool-card",
            "tutor-card",
            "student-ai-disclosure",
            "classroom-aup",
            "clinical-ai-card",
            "incident-card",
            "other"
          ]
        },
        "url": { "type": "string", "format": "uri" },
        "fetched_at": {
          "description": "RFC 3339 timestamp the document was retrieved for this review.",
          "type": "string",
          "format": "date-time"
        },
        "content_hash": {
          "description": "Hash of the canonical-form document content. Format: <alg>:<hex>. SHA-256 is recommended.",
          "type": "string",
          "pattern": "^sha(256|384|512):[0-9a-f]+$"
        },
        "version": {
          "description": "Vendor-published version string of the reviewed document, if available.",
          "type": "string"
        }
      }
    },
    "Criteria": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "policy_uris": {
          "type": "array",
          "items": { "type": "string", "format": "uri" },
          "description": "URIs of buyer-side policy documents the review was conducted against (e.g. the buyer's own AUP, RFP requirements, regulatory checklist)."
        },
        "rubric": {
          "type": "array",
          "items": { "$ref": "#/$defs/RubricCriterion" }
        }
      }
    },
    "RubricCriterion": {
      "type": "object",
      "required": ["id", "result"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "result": {
          "type": "string",
          "enum": ["pass", "pass-with-condition", "partial", "fail", "n/a"]
        },
        "notes": { "type": "string" }
      }
    },
    "Condition": {
      "type": "object",
      "required": ["id", "description"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "enforcement": {
          "description": "How compliance with the condition is enforced.",
          "type": "string",
          "enum": ["contractual", "technical", "audit", "self-attestation", "regulatory", "other"]
        },
        "violation_response": {
          "description": "What happens if the condition is violated.",
          "type": "string"
        },
        "verification_uri": {
          "description": "URL where compliance evidence can be reviewed.",
          "type": "string",
          "format": "uri"
        }
      }
    },
    "HistoryEvent": {
      "type": "object",
      "required": ["event", "at"],
      "additionalProperties": false,
      "properties": {
        "event": {
          "type": "string",
          "enum": [
            "review_started",
            "documents_collected",
            "review_completed",
            "approved",
            "approved-with-conditions",
            "rejected",
            "rejected-with-remediation",
            "pending",
            "withdrawn",
            "expired",
            "appealed",
            "amended",
            "other"
          ]
        },
        "at": { "type": "string", "format": "date-time" },
        "actor": { "type": "string" },
        "note": { "type": "string" }
      }
    },
    "Appeals": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "deadline": { "type": "string" },
        "process_uri": { "type": "string", "format": "uri" },
        "contact": { "type": "string", "format": "email" }
      }
    },
    "Publication": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "publication_uri": { "type": "string", "format": "uri" },
        "is_public": { "type": "boolean" },
        "visibility_notes": {
          "description": "Free-form notes on the publication policy — e.g. 'redacted version published; full version available on request'.",
          "type": "string"
        }
      }
    },
    "Signature": {
      "type": "object",
      "required": ["signer", "signed_at"],
      "additionalProperties": false,
      "properties": {
        "signer": {
          "description": "Name + role of the signer.",
          "type": "string",
          "minLength": 1
        },
        "signed_at": { "type": "string", "format": "date-time" },
        "method": {
          "type": "string",
          "enum": ["digital", "wet-ink", "electronic-attestation", "cryptographic", "other"]
        },
        "key_uri": {
          "description": "URL where the public key for verification can be retrieved (for cryptographic signatures).",
          "type": "string",
          "format": "uri"
        },
        "signature_value": {
          "description": "The signature value itself, base64-encoded (for cryptographic signatures).",
          "type": "string"
        }
      }
    },
    "Withdrawal": {
      "type": "object",
      "required": ["at", "reason"],
      "additionalProperties": false,
      "properties": {
        "at": { "type": "string", "format": "date-time" },
        "reason": { "type": "string", "minLength": 1 },
        "replaces": {
          "description": "If this withdrawn decision is being replaced by a new one, the new decision_id.",
          "type": "string"
        }
      }
    }
  }
}
