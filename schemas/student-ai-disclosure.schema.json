{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mizcausevic-dev/student-ai-disclosure-spec/blob/main/student-ai-disclosure.schema.json",
  "title": "Student AI Disclosure",
  "description": "Schema for a Student AI Disclosure v0.1 document — machine-readable disclosure of how AI was used in producing a student-submitted artifact.",
  "type": "object",
  "required": [
    "disclosure_version",
    "disclosure_id",
    "created_at",
    "student",
    "assignment",
    "ai_used",
    "artifact_hash",
    "signed_by_student",
    "student_signature_at"
  ],
  "additionalProperties": false,

  "properties": {
    "disclosure_version": { "type": "string", "const": "0.1" },
    "disclosure_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "student": { "$ref": "#/$defs/Student" },
    "assignment": { "$ref": "#/$defs/Assignment" },
    "ai_used": { "type": "boolean" },
    "tools_used": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ToolUsed" }
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Role" }
    },
    "roles_other_text": { "type": "string", "minLength": 1 },
    "assistance_extent": {
      "type": "string",
      "enum": ["minor", "substantial", "primary_author"]
    },
    "assistance_pct": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "prompt_evidence_mode": {
      "type": "string",
      "enum": ["full", "hashed", "omitted"]
    },
    "prompts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Prompt" }
    },
    "artifact_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "artifact_uri": { "type": "string", "format": "uri" },
    "aup_uri": { "type": "string", "format": "uri" },
    "policy_compliant": { "$ref": "#/$defs/PolicyCompliant" },
    "signed_by_student": { "type": "boolean", "const": true },
    "student_signature_at": { "type": "string", "format": "date-time" },
    "teacher_acknowledged": { "$ref": "#/$defs/TeacherAcknowledged" }
  },

  "allOf": [
    {
      "description": "If ai_used is true, tools_used / roles / assistance_extent / prompt_evidence_mode MUST be present.",
      "if": {
        "properties": { "ai_used": { "const": true } },
        "required": ["ai_used"]
      },
      "then": {
        "required": ["tools_used", "roles", "assistance_extent", "prompt_evidence_mode"]
      }
    },
    {
      "description": "If ai_used is false, AI-only fields MUST NOT be present.",
      "if": {
        "properties": { "ai_used": { "const": false } },
        "required": ["ai_used"]
      },
      "then": {
        "not": {
          "anyOf": [
            { "required": ["tools_used"] },
            { "required": ["roles"] },
            { "required": ["assistance_extent"] },
            { "required": ["assistance_pct"] },
            { "required": ["prompt_evidence_mode"] },
            { "required": ["prompts"] }
          ]
        }
      }
    },
    {
      "description": "If prompt_evidence_mode is full or hashed, prompts MUST be present.",
      "if": {
        "properties": {
          "prompt_evidence_mode": { "enum": ["full", "hashed"] }
        },
        "required": ["prompt_evidence_mode"]
      },
      "then": {
        "required": ["prompts"]
      }
    },
    {
      "description": "If prompt_evidence_mode is omitted, prompts MUST NOT be present.",
      "if": {
        "properties": { "prompt_evidence_mode": { "const": "omitted" } },
        "required": ["prompt_evidence_mode"]
      },
      "then": {
        "not": { "required": ["prompts"] }
      }
    },
    {
      "description": "If roles contains 'other', roles_other_text MUST be present.",
      "if": {
        "properties": {
          "roles": { "type": "array", "contains": { "const": "other" } }
        },
        "required": ["roles"]
      },
      "then": {
        "required": ["roles_other_text"]
      }
    }
  ],

  "$defs": {
    "Student": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string", "minLength": 1 },
        "grade_or_year": { "type": "string", "minLength": 1 },
        "institution_id": { "type": "string", "minLength": 1 }
      }
    },

    "Assignment": {
      "type": "object",
      "required": ["id", "title", "course_id"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "course_id": { "type": "string", "minLength": 1 },
        "lms": {
          "type": "string",
          "enum": ["canvas", "schoology", "google-classroom", "moodle", "d2l-brightspace", "blackboard", "other"]
        },
        "due_at": { "type": "string", "format": "date-time" }
      }
    },

    "ToolUsed": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "provider": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "agent_card_uri": { "type": "string", "format": "uri" },
        "tutor_card_uri": { "type": "string", "format": "uri" }
      }
    },

    "Role": {
      "type": "string",
      "enum": [
        "brainstorm",
        "outline",
        "draft",
        "edit",
        "translate",
        "cite_check",
        "code_completion",
        "code_review",
        "research_synthesis",
        "tutor_dialog",
        "image_generation",
        "data_analysis",
        "other"
      ]
    },

    "Prompt": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "text": { "type": "string", "minLength": 1 },
        "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "at": { "type": "string", "format": "date-time" },
        "tool_index": { "type": "integer", "minimum": 0 }
      },
      "oneOf": [
        { "required": ["text"], "not": { "required": ["hash"] } },
        { "required": ["hash"], "not": { "required": ["text"] } }
      ]
    },

    "PolicyCompliant": {
      "type": "object",
      "required": ["declared"],
      "additionalProperties": false,
      "properties": {
        "declared": { "type": "boolean" },
        "reason": { "type": "string", "minLength": 1 }
      }
    },

    "TeacherAcknowledged": {
      "type": "object",
      "required": ["acknowledged", "by", "at"],
      "additionalProperties": false,
      "properties": {
        "acknowledged": { "type": "boolean" },
        "by": { "type": "string", "minLength": 1 },
        "at": { "type": "string", "format": "date-time" },
        "note": { "type": "string", "minLength": 1 }
      }
    }
  }
}
